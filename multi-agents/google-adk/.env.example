# Copy to `.env` in this directory. Docker Compose substitutes these into `adk-web` (see docker-compose*.yml).

LITELLM_MODEL_NAME=openai/gemma3
LITELLM_API_BASE=https://sarvam-api
LITELLM_API_KEY=sk-dummy

# Integrated stack (docker-compose.integrated.yml): point at the llama-server service, e.g.
# LITELLM_API_BASE=http://llama-server:8080/v1

# ADK-only compose + llama on the host (docker-compose.yml), e.g.
# LITELLM_API_BASE=http://host.docker.internal:80/v1
