# Copy to .env. ADK uses the LiteLLM Python library; these point at your OpenAI-compatible server.
#
# docker-compose.integrated.yml overrides LITELLM_API_BASE to http://llama-server:8080/v1 (ignore the line below for that file).

# llama.cpp from coding_agents/llm_api/llama-cpp-sarvam.yml maps host port 80 -> server (alias gemma3).
# From the ADK container, use host.docker.internal (see docker-compose extra_hosts on Linux).
LITELLM_API_BASE=http://host.docker.internal:80/v1

# Must match the llama-server --alias (gemma3) when using the openai/ provider prefix.
LITELLM_MODEL_NAME=openai/gemma3

# llama.cpp often accepts any string; use a placeholder if the server does not check auth.
LITELLM_API_KEY=sk-dummy
